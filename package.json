{
  "name": "malphite",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "engines": {
    "node": ">24.0.0"
  },
  "scripts": {
    "malphite": "r malphite",
    "prepare": "husky",
    "typecheck": "tsc -b tsconfig.json --verbose",
    "lint-staged": "lint-staged",
    "postinstall": "pnpm malphite init"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "typescript": "catalog:",
    "@malphite-tool/cli": "workspace:^",
    "@malphite/core": "workspace:^",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true",
      "biome check --write --no-errors-on-unmatched",
      "biome check --write --unsafe --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched",
      "biome lint --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
