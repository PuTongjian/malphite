{
  "compilerOptions": {
    // ========== 严格性检查 / Strictness Checks ==========
    // 启用所有严格的类型检查选项 / Enable all strict type-checking options
    "strict": true,
    // 使用 verbatim 模块语法，在导入导出时保留原始的导入导出语句 / Emit verbatim module syntax for imports/exports
    "verbatimModuleSyntax": true,
    // 禁用不精确的可选属性类型（目前关闭以提高灵活性）/ Disable exact optional property types for flexibility
    "exactOptionalPropertyTypes": false,
    // 禁止 switch 语句中的 fall-through 情况 / Disallow fall-through cases in switch statements
    "noFallthroughCasesInSwitch": true,
    // 禁止隐式覆盖基类方法 / Disallow implicit method overrides
    "noImplicitOverride": true,
    // 禁止函数中不返回值的情况 / Disallow implicit return in functions
    "noImplicitReturns": true,
    // 禁止未使用的局部变量 / Disallow unused local variables
    "noUnusedLocals": true,
    // 禁止未使用的函数参数 / Disallow unused function parameters
    "noUnusedParameters": true,
    // 允许通过索引签名访问属性（目前关闭）/ Allow access to properties via index signatures
    "noPropertyAccessFromIndexSignature": false,
    // 允许未检查的索引访问（目前关闭）/ Allow unchecked indexed access
    "noUncheckedIndexedAccess": false,
    // 跳过第三方库的类型检查 / Skip type checking of third-party declaration files
    "skipLibCheck": true,

    // ========== 模块配置 / Module Configuration ==========
    // 使用 ESNext 作为输出的模块格式 / Use ESNext as the module output format
    "module": "ESNext",
    // 使用 bundler 模块解析策略 / Use bundler module resolution strategy
    "moduleResolution": "bundler",
    // 允许导入 JSON 文件 / Allow importing JSON modules
    "resolveJsonModule": true,
    // 指定类型声明文件的查找目录 / Specify the base directory for type declaration file lookup
    "typeRoots": ["./node_modules/@types"],

    // ========== 输出配置 / Emit Configuration ==========
    // 编译目标的 JavaScript 库 / Target JavaScript library (ES2024 features)
    "lib": ["ES2024"],
    // 编译输出的 JavaScript 目标版本 / Compile target JavaScript version (ES2024)
    "target": "ES2024",
    // 对于类字段，不使用 Object.defineProperty / Do not use Object.defineProperty for class fields
    "useDefineForClassFields": false,
    // 生成声明文件 (.d.ts) / Generate declaration files (.d.ts)
    "declaration": true,
    // 为声明文件生成源映射 / Generate source maps for declaration files
    "declarationMap": true,
    // 为编译后的 JavaScript 生成源映射 / Generate source maps for JavaScript files
    "sourceMap": true,
    // 移除仅用于类型的导入语句 / Remove unused imports that are only used for types
    "importsNotUsedAsValues": "remove",

    // ========== 互操作约束 / Interop Constraints ==========
    // 强制在文件名中保持一致的大小写 / Enforce consistent casing in filenames
    "forceConsistentCasingInFileNames": true,
    // 允许对 CommonJS 模块使用默认导入 / Allow default imports from CommonJS modules
    "allowSyntheticDefaultImports": true,
    // 确保每个文件都可以被安全地转译而不依赖其他文件 / Ensure each file can be safely transpiled independently
    "isolatedModules": true,

    // ========== 项目配置 / Project Configuration ==========
    // 此项目是 TypeScript 项目引用的一部分 / This project is part of TypeScript project references
    "composite": true
  },
  "include": [],
  "files": [],
  "exclude": ["node_modules", "target", "dist", "lib"],
  // 项目引用 / Project References
  "references": [{ "path": "./tools/cli" }]
}
